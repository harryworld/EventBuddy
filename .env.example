# Copy this file to .env and fill in the target you actually use.

# Default publish target: r2, pages, or kv.
EVENTBUDDY_EVENTS_TARGET=r2

# R2 object upload.
EVENTBUDDY_R2_BUCKET=
EVENTBUDDY_R2_OBJECT_KEY=events.json
EVENTBUDDY_R2_CACHE_CONTROL="public, max-age=300"

# Cloudflare Pages direct upload. Use only for a feed-only Pages project.
EVENTBUDDY_PAGES_PROJECT=
EVENTBUDDY_PAGES_BRANCH=main

# Workers KV upload.
EVENTBUDDY_KV_NAMESPACE_ID=
EVENTBUDDY_KV_KEY=events.json
